<input type="hidden" id="user-select-count" value="<%=@user_count %>" />
<table id="user-select-list" class="table table-hover"<% unless @users %> style="display:none"<% end %> data-user-select-target="userList">
  <colgroup>
    <col style="width:100px;" />
    <col />
    <col />
    <col />
  </colgroup>
  <thead>
  <tr class="thead-default">
    <th>
      <% if params['multiple'] %>
      <input type="checkbox" id="user_select_check_all" class="me-2">
        <% end %>
        <%=t(:check) %></th>
    <th><%=t(:name) %></th>
    <th><%=t(:phone) %></th>
  </tr>
  </thead>
  <tbody>
  <% unless @user_count.zero? %>
    <% @users.each do |user| %>
      <tr>
        <td>
          <% if params['multiple'] %>
            <input type="checkbox" name="id[]" value="<%=user.id %>">
            <% else %>
            <input type="radio" name="id[]" value="<%=user.id %>">
          <% end %>
            </td>
        <td class="name"><%=user.name %></td>
        <td class="phone"><%=user.phone %></td>
      </tr>
    <% end %>
  <% else %>
    <tr>
      <td><%=t(:no_data) %></td>
    </tr>
  <% end %>
  </tbody>
</table>
<div class="sl_pagination">
</div>