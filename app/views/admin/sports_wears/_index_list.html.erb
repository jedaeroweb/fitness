<div class="row">
  <div class="col-12">
    <div id="blog-main" class="table-responsive">
      <table class="table table-bordered table-hover">
        <colgroup>
          <col style="width:100px">
          <col>
          <col>
          <col style="width:150px">
          <% if can?(:update, SportsWear) or can?(:delete, SportsWear) %>
            <col<%= manage_width(SportsWear) %>>
          <% end %>
        </colgroup>
        <thead class="thead-default">
        <tr>
          <th><%= t(:order_no, scope: [:activerecord, :attributes, :course]) %></th>
          <th><%= t(:title, scope: [:activerecord, :attributes, :course]) %></th>
          <th class="text-end"><%= t(:price, scope: [:activerecord, :attributes, :course]) %></th>
          <th class="text-center"><%= t(:content, scope: [:activerecord, :attributes, :product_content]) %></th>
          <th class="text-center"><%= t(:manage) %></th>
        </tr>
        </thead>
        <tbody data-controller="modal">
        <% unless @sports_wears.empty? %>
          <% @sports_wears.each_with_index do |sports_wear, index| %>
            <tr>
              <td><%= sports_wear.product.order_no %></td>
              <td><%= link_to sports_wear.product.title, admin_course_path(sports_wear, category: params[:category]) %></td>
              <td class="text-end"><%=number_to_currency sports_wear.product.price %></td>
              <td class="text-center">
                <% if sports_wear.product.product_content.present? %>
                  <%= link_to t(:show_content), admin_product_content_path(sports_wear.product.product_content), { class: 'btn btn-secondary', 'data-action'=>"click->modal#open" } %>
                <% else %>
                  <%= link_to t(:new_content), new_admin_product_content_path(product_id: sports_wear.product), { class: 'btn btn-secondary', 'data-action'=>"click->modal#open" } %>
                <% end %>
              </td>
              <% if can?(:update, sports_wear) or can?(:delete, sports_wear) %>
                <td class="text-center">
                  <% if can? :update, sports_wear %>
                    <%= link_to edit_admin_sports_wear_path(sports_wear), :class => "btn btn-secondary" do %>
                      <%= t(:edit) %>
                    <% end %>
                  <% end %>
                  <% if can? :delete, sports_wear %>
                    <%= link_to admin_sports_wear_path(sports_wear), :method => :delete, :data => { :confirm => t(:delete_cascade_confirm) }, :class => "btn btn-danger" do %>
                      <%= t(:delete) %>
                    <% end %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center"><%= t(:no_data) %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
      <div id="sl_bottom_menu">
        <%= paginate @sports_wears %>
      </div>
    </div>
  </div>
  <div class="col-12">
    <%=link_to t(:new_course),new_admin_sports_wear_path(category: params[:category]),class: 'btn btn-primary btn-large' %>
  </div>
</div>